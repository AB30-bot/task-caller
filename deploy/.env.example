# Copy to ../.env (project root) and fill in. Both server.py and openwa load it.

# --- Secrets ---
GEMINI_API_KEY=your-gemini-api-key-here
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- Call routing ---
LIVE_USE_TURN=1                              # 1 = relay media via Twilio (needed for phones / cross-network)
LIVE_DOMAIN=your-stable-domain.example.com   # host used to build the call link in WhatsApp (no https://)
LIVE_MODEL=models/gemini-2.5-flash-native-audio-preview-12-2025
LIVE_VOICE=Charon
SUMMARIZER_MODEL=models/gemini-2.5-flash
MAX_SECONDS=300

# --- WhatsApp ---
OPENWA_URL=http://localhost:3000
ADAM_WHATSAPP=+15551234567                   # operator's number — receives call summaries
DEFAULT_COUNTRY_CODE=1                        # bare numbers get this prefix; set to YOUR country code in .env

# --- Linux browser for the WhatsApp gateway (puppeteer) ---
CHROME_PATH=/usr/bin/chromium-browser

# --- Server / cloudflared ---
PORT=7860
LOG_LEVEL=INFO
CF_TUNNEL_TOKEN=                             # token from a Cloudflare named tunnel (stable URL); see deploy notes
